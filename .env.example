# Copy to ".env" for local development (never commit real secrets).
# Expo exposes only variables prefixed with EXPO_PUBLIC_ to the client bundle.

EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-anon-or-publishable-key
EXPO_PUBLIC_BACKEND_URL=http://localhost:3000/api
# Set to true for local UI preview without login (never use in production)
EXPO_PUBLIC_SKIP_AUTH=false
