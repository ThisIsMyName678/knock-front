# Copy to ".env" for local development (never commit real secrets).
# Expo exposes only variables prefixed with EXPO_PUBLIC_ to the client bundle.

EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-anon-or-publishable-key
# Simulator/emulator: localhost works.
# Physical device: use your PC's LAN IP (e.g. ipconfig → 192.168.x.x), not localhost.
EXPO_PUBLIC_BACKEND_URL=http://localhost:3000/api
# Set to true for local UI preview without login (never use in production)
EXPO_PUBLIC_SKIP_AUTH=false

# Supabase Auth → URL Configuration → Redirect URLs (add all that apply):
#   knocknock://reset-password
#   exp://127.0.0.1:8081/--/reset-password
#   exp://YOUR_LAN_IP:8081/--/reset-password
# Use `npx expo-linking` or log getPasswordResetRedirectUrl() in dev to see the exact Expo Go URL.
